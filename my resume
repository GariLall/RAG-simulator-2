<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Resume</title>
    <style>
        :root {
            --primary: #2563eb;
            --dark: #1e293b;
            --light: #f8fafc;
            --text: #334155;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: system-ui, -apple-system, sans-serif;
        }

        body {
            background-color: var(--light);
            color: var(--text);
            line-height: 1.5;
            padding: 2rem;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        }

        header {
            text-align: center;
            border-bottom: 2px solid var(--light);
            padding-bottom: 1.5rem;
            margin-bottom: 1.5rem;
        }

        h1 { color: var(--dark); margin-bottom: 0.5rem; }
        h2 { color: var(--primary); margin: 1.5rem 0 0.5rem; }
        
        .contact {
            font-size: 0.9rem;
            color: #64748b;
        }

        .skills-container {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        .skill-tag {
            background: var(--light);
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .job, .edu {
            margin-bottom: 1rem;
        }

        .job-title, .edu-title {
            font-weight: bold;
            color: var(--dark);
        }

        .meta {
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 0.25rem;
        }

        ul {
            padding-left: 1.25rem;
            margin-top: 0.25rem;
        }

        /* Interactive Dark Mode Button */
        .theme-btn {
            position: fixed;
            top: 1rem;
            right: 1rem;
            background: var(--dark);
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 4px;
            cursor: pointer;
        }

        /* Dark Mode Styles */
        body.dark-theme {
            --light: #1e293b;
            --dark: #f8fafc;
            --text: #cbd5e1;
            background-color: #0f172a;
        }
        body.dark-theme .container {
            background: #1e293b;
        }
        body.dark-theme .theme-btn {
            background: #f8fafc;
            color: #0f172a;
        }
    </style>
</head>
<body>

    <button class="theme-btn" onclick="toggleTheme()">Toggle Dark Mode</button>

    <div class="container">
        <header>
            <h1 id="name-placeholder">[Your Name]</h1>
            <div class="contact">
                Email: your.email@example.com | Phone: (555) 123-4567 | Location: Brambleton, VA
            </div>
        </header>

        <section>
            <h2>Professional Summary</h2>
            <p>A placeholder summary detailing your career goals, key strengths, and professional background. Click the button above to test the interactive dark mode layout.</p>
        </section>

        <section>
            <h2>Skills</h2>
            <div class="skills-container">
                <span class="skill-tag">HTML5 & CSS3</span>
                <span class="skill-tag">JavaScript (ES6+)</span>
                <span class="skill-tag">Tailwind CSS</span>
                <span class="skill-tag">Git & GitHub</span>
                <span class="skill-tag">Responsive Design</span>
            </div>
        </section>

        <section>
            <h2>Experience</h2>
            <div class="job">
                <div class="job-title">Job Title / Role</div>
                <div class="meta">Company Name | Start Date - Present</div>
                <ul>
                    <li>Accomplishment or daily responsibility description goes here.</li>
                    <li>Quantifiable metric or project milestone achieved in this role.</li>
                </ul>
            </div>
        </section>

        <section>
            <h2>Education</h2>
            <div class="edu">
                <div class="edu-title">Degree or Certification Name</div>
                <div class="meta">Institution Name | Graduation Year</div>
            </div>
        </section>
    </div>

    <script>
        // Simple interactive function to toggle dark mode
        function toggleTheme() {
            document.body.classList.toggle('dark-theme');
        }

        // Prompting for user name just to showcase dynamic JS population
        window.addEventListener('DOMContentLoaded', () => {
            const name = prompt("Enter your name to populate the resume:") || "Your Name";
            document.getElementById('name-placeholder').textContent = name;
        });
    </script>
</body>
</html>
